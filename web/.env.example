# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Twitter API v2 Configuration
# Required for tweet verification during registration
# Get your bearer token at: https://developer.twitter.com/en/portal/projects
TWITTER_BEARER_TOKEN=

# =============================================================================
# NEAR Protocol Configuration for Intents
# =============================================================================
#
# QUICK START (Testnet):
# 1. Create a testnet account at https://wallet.testnet.near.org
# 2. Export your private key from the wallet
# 3. Set the values below and set NEAR_DEMO_MODE=false
#
# MAINNET DEPLOYMENT:
# 1. Create a mainnet account at https://wallet.near.org
# 2. Fund with ~1 NEAR for gas fees
# 3. Set NEAR_NETWORK=mainnet
# 4. Test with small amounts ($1-5) before full launch
#
# For more info: https://docs.near.org/

# Network: "testnet" or "mainnet"
NEAR_NETWORK=testnet

# NEAR account for signing transactions (e.g., tipz.testnet or tipz.near)
NEAR_ACCOUNT_ID=your-account.testnet

# NEAR private key (ed25519:...) - keep this secret!
# Export from wallet or use near-cli: near keys <account-id>
NEAR_PRIVATE_KEY=ed25519:your-private-key

# Set to "true" to use mock APIs (demo mode)
# Set to "false" to use real NEAR blockchain
NEAR_DEMO_MODE=true

# Swap Provider API Keys (optional)
THORCHAIN_API_KEY=
ONEINCH_API_KEY=

# CoinGecko API Key (optional, for price data)
COINGECKO_API_KEY=
