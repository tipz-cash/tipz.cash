# =============================================================================
# TIPZ Environment Configuration
# =============================================================================
#
# REQUIREMENTS:
# - Supabase: Required for creator registration and transaction logging
# - Twitter API: Required for tweet verification (or set to pending/manual)
# - NEAR: Required for payments via NEAR Intents
#   - Valid NEAR_ACCOUNT_ID and NEAR_PRIVATE_KEY
#   - (Optional) TWITTER_BEARER_TOKEN for automated verification
#
# =============================================================================

# -----------------------------------------------------------------------------
# Basic Auth (Optional - for staging/preview protection)
# -----------------------------------------------------------------------------
# Set both to enable site-wide password protection
# Leave empty to disable (default for local dev)
BASIC_AUTH_USERNAME=
BASIC_AUTH_PASSWORD=

# -----------------------------------------------------------------------------
# Supabase Configuration (Required)
# -----------------------------------------------------------------------------
# Get credentials at: https://supabase.com/dashboard/project/_/settings/api
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your-service-key

# Public keys for client-side Realtime subscriptions (used on /my dashboard)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# -----------------------------------------------------------------------------
# Twitter API v2 Configuration (Recommended)
# -----------------------------------------------------------------------------
# Required for automated tweet verification during registration.
# Without this, registrations default to "pending" status (manual review).
#
# Get your bearer token at: https://developer.twitter.com/en/portal/projects
# Required scopes: tweet.read, users.read
TWITTER_BEARER_TOKEN=

# -----------------------------------------------------------------------------
# NEAR Protocol Configuration for Intents (Required for real payments)
# -----------------------------------------------------------------------------
#
# QUICK START (Testnet):
# 1. Create account: https://wallet.testnet.near.org
# 2. Export private key from wallet settings
# 3. Set values below
# 4. Test with small amounts first!
#
# MAINNET DEPLOYMENT:
# 1. Create account: https://wallet.near.org
# 2. Fund with ~1 NEAR for gas (~$3-5)
# 3. Set NEAR_NETWORK=mainnet
# 4. Test with $1-5 tips before full launch
#
# Docs: https://docs.near.org/

# Network: "testnet" or "mainnet"
NEAR_NETWORK=testnet

# NEAR account for signing transactions
# Examples: tipz.testnet, tipz.near, your-name.testnet
NEAR_ACCOUNT_ID=

# NEAR private key (ed25519:...) - KEEP THIS SECRET!
# Export from wallet or use: near keys <account-id>
NEAR_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# NEAR Intents 1Click API Configuration
# -----------------------------------------------------------------------------
#
# NEAR Intents enables cross-chain swaps from ETH/USDC to ZEC.
# This is the same infrastructure used by Zashi wallet for swaps.
#
# SETUP:
# 1. Register at: https://partners.near-intents.org
# 2. Get your JWT token (optional, avoids 0.1% fee)
#
# API Docs: https://docs.near-intents.org/near-intents/integration/distribution-channels/1click-api

# JWT token from NEAR Intents Partners Portal (optional, avoids 0.1% fee)
NEAR_INTENTS_JWT=

# -----------------------------------------------------------------------------
# Optional: Legacy Swap Provider API Keys
# -----------------------------------------------------------------------------
# Not currently used - reserved for future THORChain/1inch integration
THORCHAIN_API_KEY=
ONEINCH_API_KEY=

# -----------------------------------------------------------------------------
# Optional: CoinGecko API Key
# -----------------------------------------------------------------------------
# Free tier works without key (rate limited). Pro key for higher limits.
COINGECKO_API_KEY=


# -----------------------------------------------------------------------------
# Twitter OAuth 2.0 (PKCE) — for creator login on tipz.cash/my
# -----------------------------------------------------------------------------
# Public OAuth 2.0 Client ID from Twitter Developer Portal.
# Uses PKCE flow (no client secret needed).
# Required scopes: tweet.read, users.read
# Callback URL: https://tipz.cash/api/auth/twitter/callback
TWITTER_CLIENT_ID=

# -----------------------------------------------------------------------------
# Session Secret — for signing JWT session cookies
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
SESSION_SECRET=
