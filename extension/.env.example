# TIPZ Extension Configuration

# API URL - points to the TIPZ web app
PLASMO_PUBLIC_API_URL=http://localhost:3000

# WalletConnect Project ID (optional, MetaMask fallback available)
# Get your project ID at: https://cloud.walletconnect.com/
PLASMO_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Demo Mode - Set to "false" for production (real transactions)
# When true, swap quotes and transactions are simulated
PLASMO_PUBLIC_DEMO_MODE=true

# Dev Mode - Set to "true" to show TIP button on ALL tweets (testing only)
# When true, returns mock creator data for any handle
# WARNING: Only use for local development!
PLASMO_PUBLIC_DEV_MODE=false
